<Page
    x:Class="App.Pages.Menus.Report.SellersReportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ic="using:FluentIcons.WinUI"
    xmlns:local="using:App.Pages.Menus.Report"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:App.ViewModels"
    Padding="10"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Margin="0,0,0,5">
            <ItemsRepeater x:Name="IvSellers" VerticalAlignment="Stretch">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:SellerReportViewModel">
                        <Expander
                            Margin="0,4,0,4"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch">
                            <Expander.Header>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind SellerName}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Opacity="0.7"
                                        Text="{x:Bind TotalShareAmountText}" />
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="2">
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.5*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        x:Uid="/SellersReportPage/ItemNameTextBlock"
                                        Grid.Column="0"
                                        HorizontalAlignment="Left"
                                        FontWeight="SemiBold" />
                                    <TextBlock
                                        x:Uid="/SellersReportPage/ItemSharePercentageTextBlock"
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        FontWeight="SemiBold" />
                                    <TextBlock
                                        x:Uid="/SellersReportPage/ItemQuantityTextBlock"
                                        Grid.Column="2"
                                        HorizontalAlignment="Center"
                                        FontWeight="SemiBold" />
                                    <TextBlock
                                        x:Uid="/SellersReportPage/ItemShareAmountTextBlock"
                                        Grid.Column="3"
                                        HorizontalAlignment="Center"
                                        FontWeight="SemiBold" />
                                </Grid>
                                <ItemsRepeater ItemsSource="{x:Bind Items}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SellerReportItemViewModel">
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.5*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    Text="{x:Bind ItemName}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Text="{x:Bind PercentageText}" />
                                                <TextBlock
                                                    Grid.Column="2"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Text="{x:Bind QuantityText}" />
                                                <TextBlock
                                                    Grid.Column="3"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Text="{x:Bind ShareAmountText}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Expander>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                x:Uid="/SellersReportPage/TotalTextBlock"
                Grid.Column="0"
                HorizontalAlignment="Left"
                FontWeight="Bold" />
            <TextBlock
                x:Name="TotalShareAmountTextBlock"
                Grid.Column="1"
                HorizontalAlignment="Right"
                FontWeight="Bold" />
        </Grid>
    </Grid>
</Page>
